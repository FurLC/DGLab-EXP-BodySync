# Third-party binary dependencies
# Keep explicit allowlist for bundled runtime deps; avoid committing debug symbols
BepInExPlugin/lib/*.dll
BepInExPlugin/lib/*.xml
BepInExPlugin/lib/*.pdb
!BepInExPlugin/lib/QRCoder.dll
!BepInExPlugin/lib/websocket-sharp.dll
!BepInExPlugin/lib/Newtonsoft.Json.dll

# Keep optional documentation in lib if added later
!BepInExPlugin/lib/README.md
!BepInExPlugin/lib/README.txt

